{
    "name": "restream",
    "version": "1.0.0",
    "description": "A streaming server which takes inputs and replicates them to multiple outputs.",
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "npx nodemon --ignore 'test/artifacts/**' src/index.js",
        "test": "echo \"Error: no test specified\" && exit 1",
        "test:setup:4x3": "bash test/artifacts/setup-4x3-copy.sh",
        "test:start-inputs:4x3": "bash test/artifacts/start-inputs-from-manifest.sh test/artifacts/session-4x3-last.json",
        "test:start-outputs:4x3": "bash test/artifacts/start-outputs-from-manifest.sh test/artifacts/session-4x3-last.json",
        "test:health:snapshot": "bash test/artifacts/health-snapshot.sh",
        "test:screenshot:dashboard": "node test/artifacts/capture-dashboard-screenshots.mjs"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "engines": {
        "node": ">=20.19.0 <26",
        "npm": ">=10"
    },
    "dependencies": {
        "better-sqlite3": "12.6.0",
        "body-parser": "2.2.2",
        "cors": "2.8.5",
        "express": "5.1.0"
    },
    "devDependencies": {
        "@tailwindcss/cli": "4.1.18",
        "daisyui": "5.5.14",
        "nodemon": "3.1.11",
        "playwright": "^1.59.1",
        "prettier": "3.7.4",
        "prettier-plugin-tailwindcss": "0.7.2",
        "tailwindcss": "4.1.18"
    }
}
